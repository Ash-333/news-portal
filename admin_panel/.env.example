# Core runtime
NODE_ENV=production
DATABASE_URL=postgresql://postgres:postgres@db-host:5432/news_portal?schema=public

# Auth and tokens
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12

# App URLs and API access
APP_NAME=News Portal
APP_URL=http://localhost:3000
CORS_ALLOWED_ORIGIN=http://localhost:3001

# Optional cron protection
CRON_SECRET=

# Optional email settings
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=News Portal <noreply@example.com>

# Optional rate limiting overrides
RATE_LIMIT_LOGIN=5
RATE_LIMIT_LOGIN_WINDOW=900
RATE_LIMIT_COMMENTS=5
RATE_LIMIT_COMMENTS_WINDOW=3600
RATE_LIMIT_API=100
RATE_LIMIT_API_WINDOW=60
