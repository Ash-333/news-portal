generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PUBLIC_USER
  AUTHOR
  ADMIN
  SUPERADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
}

enum ArticleStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
  SCHEDULED
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum AdStatus {
  ACTIVE
  INACTIVE
  SCHEDULED
}

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
  SPAM
}

enum Language {
  NEPALI
  ENGLISH
}

enum Province {
  PROVINCE_1
  PROVINCE_2
  PROVINCE_3
  PROVINCE_4
  PROVINCE_5
  PROVINCE_6
  PROVINCE_7
}

model User {
  id               String     @id @default(uuid())
  email            String     @unique
  passwordHash     String?
  name             String     @map("name_en")
  nameNe           String?    @map("name_ne")
  profilePhoto     String?    @map("profile_photo")
  bio              String?
  role             Role       @default(PUBLIC_USER)
  status           UserStatus @default(ACTIVE)
  language         Language   @default(ENGLISH)
  lastLoginAt      DateTime?
  deletedAt        DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  // Relations
  articles       Article[]
  comments       Comment[]
  bookmarks      Bookmark[]
  media          Media[]
  auditLogs      AuditLog[]
  notifications  Notification[]
  videos         Video[]
  advertisements Advertisement[]
  flashUpdates   FlashUpdate[]
  pollVotes      PollVote[]
  horoscopes     Horoscope[]
  audioNews      AudioNews[]
  photoGalleries PhotoGallery[]

  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model Category {
  id        String   @id @default(uuid())
  nameNe    String   @map("name_ne")
  nameEn    String   @map("name_en")
  slug      String   @unique
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  parent   Category?  @relation("CategoryParent", fields: [parentId], references: [id])
  children Category[] @relation("CategoryParent")
  articles Article[]
  audioNews AudioNews[]

  @@index([parentId])
  @@index([deletedAt])
  @@map("categories")
}

model Tag {
  id     String @id @default(uuid())
  nameNe String @map("name_ne")
  nameEn String @map("name_en")
  slug   String @unique

  // Relations
  articles ArticleTag[]

  @@map("tags")
}

model Article {
  id              String        @id @default(uuid())
  titleNe         String        @map("title_ne")
  titleEn         String        @map("title_en")
  subheadingNe    String?       @map("subheading_ne")
  subheadingEn    String?       @map("subheading_en")
  contentNe       String        @map("content_ne")
  contentEn       String        @map("content_en")
  excerptNe       String?       @map("excerpt_ne")
  excerptEn       String?       @map("excerpt_en")
  summaryNe       String?       @map("summary_ne")
  summaryEn       String?       @map("summary_en")
  slug            String        @unique
  status          ArticleStatus @default(DRAFT)
  isBreaking      Boolean       @default(false) @map("is_breaking")
  isFeatured      Boolean       @default(false) @map("is_featured")
  province       Province?     @map("province")
  scheduledAt     DateTime?     @map("scheduled_at")
  publishedAt     DateTime?     @map("published_at")
  viewCount       Int           @default(0) @map("view_count")
  authorId        String        @map("author_id")
  categoryId      String        @map("category_id")
  metaTitle       String?       @map("meta_title")
  metaDescription String?       @map("meta_description")
  ogImage         String?       @map("og_image")
  featuredImageId String?       @map("featured_image_id")
  deletedAt       DateTime?     @map("deleted_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Relations
  author    User         @relation(fields: [authorId], references: [id])
  category  Category     @relation(fields: [categoryId], references: [id])
  featuredImage Media?   @relation(fields: [featuredImageId], references: [id])
  tags      ArticleTag[]
  comments  Comment[]
  bookmarks Bookmark[]
  pageViews PageView[]

  @@index([status])
  @@index([publishedAt])
  @@index([authorId])
  @@index([categoryId])
  @@index([isBreaking])
  @@index([isFeatured])
  @@index([province])
  @@index([deletedAt])
  @@index([status, deletedAt, publishedAt])
  @@index([status, deletedAt, authorId])
  @@map("articles")
}

model ArticleTag {
  articleId String @map("article_id")
  tagId     String @map("tag_id")

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([articleId])
  @@index([tagId])
  @@map("article_tags")
}

model Media {
  id         String    @id @default(uuid())
  filename   String
  title      String?   @map("title")
  url        String
  type       MediaType
  altText    String?   @map("alt_text")
  size       Int
  uploadedBy String    @map("uploaded_by")
  createdAt  DateTime  @default(now()) @map("created_at")

  // Relations
  uploader                 User                  @relation(fields: [uploadedBy], references: [id])
  featuredInArticles       Article[]
  featuredInFlashUpdates   FlashUpdate[]
  coverInGalleries         PhotoGallery[]        @relation("CoverPhotoGallery")
  galleryPhotos            PhotoGalleryPhoto[]

  @@index([uploadedBy])
  @@index([type])
  @@map("media")
}

model Comment {
  id          String        @id @default(uuid())
  content     String
  status      CommentStatus @default(PENDING)
  articleId   String        @map("article_id")
  userId      String        @map("user_id")
  parentId    String?       @map("parent_id")
  likesCount  Int           @default(0) @map("likes_count")
  reportCount Int           @default(0) @map("report_count")
  editedAt    DateTime?     @map("edited_at")
  deletedAt   DateTime?     @map("deleted_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  article Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id])
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  @@index([articleId])
  @@index([status])
  @@index([userId])
  @@index([deletedAt])
  @@map("comments")
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  articleId String   @map("article_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([userId])
  @@index([articleId])
  @@map("bookmarks")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  targetType String   @map("target_type")
  targetId   String?  @map("target_id")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model SiteSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model Video {
  id            String    @id @default(uuid())
  titleNe       String    @map("title_ne")
  titleEn       String    @map("title_en")
  youtubeUrl    String    @map("youtube_url")
  thumbnailUrl  String    @map("thumbnail_url")
  iframeUrl     String    @map("iframe_url")
  authorId      String    @map("author_id")
  isPublished   Boolean   @default(false) @map("is_published")
  publishedAt   DateTime? @map("published_at")
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  author User @relation(fields: [authorId], references: [id])

  @@index([authorId])
  @@index([isPublished])
  @@index([deletedAt])
  @@map("videos")
}

model Advertisement {
  id        String    @id @default(uuid())
  titleNe   String    @map("title_ne")
  titleEn   String    @map("title_en")
  mediaUrl  String    @map("media_url")
  mediaType String    @default("IMAGE") @map("media_type")
  linkUrl   String?   @map("link_url")
  position  String    @default("SIDEBAR")
  isActive  Boolean   @default(true) @map("is_active")
  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")
  createdBy String    @map("created_by")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  creator User @relation(fields: [createdBy], references: [id])

  @@index([isActive])
  @@index([position])
  @@index([deletedAt])
  @@index([createdBy])
  @@map("advertisements")
}

model FlashUpdate {
  id              String    @id @default(uuid())
  titleNe         String    @map("title_ne")
  titleEn         String    @map("title_en")
  contentNe       String    @map("content_ne")
  contentEn       String    @map("content_en")
  excerptNe       String?   @map("excerpt_ne")
  excerptEn       String?   @map("excerpt_en")
  slug            String    @unique
  featuredImageId String?   @map("featured_image_id")
  isPublished     Boolean   @default(false) @map("is_published")
  publishedAt     DateTime? @map("published_at")
  expiresAt       DateTime? @map("expires_at")
  authorId        String    @map("author_id")
  metaTitle       String?   @map("meta_title")
  metaDescription String?   @map("meta_description")
  ogImage         String?   @map("og_image")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  author        User   @relation(fields: [authorId], references: [id])
  featuredImage Media? @relation(fields: [featuredImageId], references: [id])

  @@index([authorId])
  @@index([isPublished])
  @@index([publishedAt])
  @@index([deletedAt])
  @@map("flash_updates")
}

// Poll Models
model Poll {
  id          String    @id @default(uuid())
  questionNe  String    @map("question_ne")
  questionEn  String    @map("question_en")
  description String?   @map("description")
  isActive    Boolean   @default(true) @map("is_active")
  isMultiple  Boolean   @default(false) @map("is_multiple")
  startsAt    DateTime? @map("starts_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  options PollOption[]
  votes  PollVote[]

  @@index([isActive])
  @@index([deletedAt])
  @@map("polls")
}

model PollOption {
  id        String   @id @default(uuid())
  textNe    String   @map("text_ne")
  textEn    String   @map("text_en")
  order     Int      @default(0)
  pollId    String   @map("poll_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  poll  Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([pollId])
  @@map("poll_options")
}

model PollVote {
  id        String   @id @default(uuid())
  pollId    String   @map("poll_id")
  optionId  String   @map("option_id")
  userId    String?  @map("user_id") // Nullable for anonymous votes
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  poll   Poll        @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([pollId, userId]) // One vote per user per poll (for single choice)
  @@index([pollId])
  @@index([optionId])
  @@index([userId])
  @@index([ipAddress])
  @@map("poll_votes")
}

// Horoscope Model
model Horoscope {
  id          String   @id @default(uuid())
  zodiacSign  String   @map("zodiac_sign") // e.g., "aries", "taurus", etc.
  icon        String   @default("Sparkles") // Lucide icon name
  titleNe     String   @map("title_ne")
  titleEn     String   @map("title_en")
  contentNe   String   @map("content_ne")
  contentEn   String   @map("content_en")
  date        DateTime @default(now()) @map("date")
  isPublished Boolean  @default(false) @map("is_published")
  authorId    String   @map("author_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  author User @relation(fields: [authorId], references: [id])

  @@index([zodiacSign])
  @@index([date])
  @@index([isPublished])
  @@index([authorId])
  @@map("horoscopes")
}

// Audio News Model
model AudioNews {
  id            String   @id @default(uuid())
  titleNe       String   @map("title_ne")
  titleEn       String   @map("title_en")
  descriptionNe String?  @map("description_ne")
  descriptionEn String?  @map("description_en")
  audioUrl      String   @map("audio_url")
  thumbnailUrl String?  @map("thumbnail_url")
  categoryId    String?  @map("category_id")
  authorId      String   @map("author_id")
  isPublished   Boolean  @default(false) @map("is_published")
  viewCount     Int      @default(0) @map("view_count")
  publishedAt   DateTime? @map("published_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  author   User      @relation(fields: [authorId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])

  @@index([authorId])
  @@index([categoryId])
  @@index([isPublished])
  @@index([publishedAt])
  @@map("audio_news")
}

// Page View Tracking Model
model PageView {
  id          String   @id @default(uuid())
  articleId   String   @map("article_id")
  slug        String
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  referrer    String?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([createdAt])
  @@index([slug])
  @@map("page_views")
}

// Team Member Model
model TeamMember {
  id          String   @id @default(uuid())
  name       String   @map("name")
  nameNe     String?  @map("name_ne")
  department String   @map("department")
  departmentNe String? @map("department_ne")
  designation String  @map("designation")
  designationNe String? @map("designation_ne")
  image      String?  @map("image")
  bio        String?
  bioNe      String?  @map("bio_ne")
  email      String?
  phone      String?
  order      Int      @default(0) @map("order")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([order])
  @@index([isActive])
  @@map("team_members")
}

// Photo Gallery Models
model PhotoGallery {
  id           String    @id @default(uuid())
  titleNe      String    @map("title_ne")
  titleEn      String    @map("title_en")
  excerptNe    String?   @map("excerpt_ne")
  excerptEn    String?   @map("excerpt_en")
  slug         String    @unique
  isPublished  Boolean   @default(false) @map("is_published")
  authorId     String    @map("author_id")
  coverImageId String?   @map("cover_image_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  author     User                    @relation(fields: [authorId], references: [id])
  coverImage Media?                  @relation("CoverPhotoGallery", fields: [coverImageId], references: [id])
  photos     PhotoGalleryPhoto[]

  @@index([slug])
  @@index([isPublished])
  @@index([authorId])
  @@map("photo_galleries")
}

model PhotoGalleryPhoto {
  id              String   @id @default(uuid())
  photoGalleryId  String   @map("photo_gallery_id")
  mediaId         String   @map("media_id")
  order           Int      @default(0)
  captionNe       String?  @map("caption_ne")
  captionEn       String?  @map("caption_en")
  createdAt       DateTime @default(now()) @map("created_at")

  photoGallery PhotoGallery @relation(fields: [photoGalleryId], references: [id], onDelete: Cascade)
  media        Media        @relation(fields: [mediaId], references: [id])

  @@unique([photoGalleryId, mediaId])
  @@index([photoGalleryId])
  @@map("photo_gallery_photos")
}
